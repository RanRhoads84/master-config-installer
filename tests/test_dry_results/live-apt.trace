map_name() {
  local name="$1"
  case "$PM" in
    apt)
      if [ "$name" = "fd" ]; then
        echo "fd-find"
        return
      fi
      if [ "$name" = "bat" ]; then
        echo "batcat"
        return
      fi
      ;;
    pacman|dnf|zypper)
      if [ "$name" = "fd-find" ]; then
        echo "fd"
        return
      fi
      ;;
  esac
  echo "$name"
}

is_installed() {
  local pkg="$1"
  case "$PM" in
    apt) dpkg -s "$pkg" >/dev/null 2>&1 && return 0 || true ;;
    pacman) pacman -Qi "$pkg" >/dev/null 2>&1 && return 0 || true ;;
    dnf|zypper) rpm -q "$pkg" >/dev/null 2>&1 && return 0 || true ;;
  esac
  if command -v "$pkg" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

